{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stellar Drift",
  "version": "1.1.341",
  "identifier": "com.stellardrift.app",
  "build": {
    "frontendDist": "../",
    "devUrl": "http://localhost:8080"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Stellar Drift",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERENTY3MTdDNzVDNjQyREIKUldUYlFzWjFmSEZXM1JPMjY3MVdWVmVWa3R5UCtTcUJNRXZtRzErZ0htK29NRzQ0Z2h4TmxMcUoK",
      "endpoints": [
        "https://github.com/vadimmorion-commits/stellar-drift/releases/latest/download/latest.json"
      ]
    }
  }
}
